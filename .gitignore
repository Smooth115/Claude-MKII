# ── Parsed EVTX output (too large for repo) ──────────────────────────────
logs/*.json
!logs/.gitkeep

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.Python
*.egg-info/
.eggs/
dist/
build/

# ── Virtual environments ─────────────────────────────────────────────────
venv/
env/
.env

# ── IDE ───────────────────────────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json
.vscode/extensions.json
.vscode/*.code-workspace
.idea/
*.swp
*.swo

# ── OS ────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Temp files ────────────────────────────────────────────────────────────
*.tmp
*.bak

